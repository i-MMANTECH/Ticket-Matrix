    {
      "name": "Tickets",
      "item": [
        {
          "name": "List tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/?ordering=-created_at",
              "host": ["{{base_url}}"],
              "path": ["tickets", ""],
              "query": [
                { "key": "ordering", "value": "-created_at" },
                { "key": "status", "value": "open", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "search", "value": "billing", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create ticket (inline customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('ticket_id', data.id);",
                  "  console.log('Saved ticket_id =', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Cannot send bulk SMS campaign\",\n  \"description\": \"Trying to launch a campaign to 5,000 contacts but the dashboard returns a generic error after upload.\",\n  \"priority\": \"urgent\",\n  \"category\": \"technical\",\n  \"status\": \"in_progress\",\n  \"assignee\": \"Support Tier 2\",\n  \"progress\": 25,\n  \"customer_name\": \"Adaeze Okafor\",\n  \"customer_email\": \"adaeze+postman@nativetalk.test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets/",
              "host": ["{{base_url}}"],
              "path": ["tickets", ""]
            }
          }
        },
