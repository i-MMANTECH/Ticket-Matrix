              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('customer_id', data.id);",
                  "  console.log('Saved customer_id =', data.id);",
                  "}"
