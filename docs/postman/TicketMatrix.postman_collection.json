          "name": "Create ticket (existing customer_id)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Voice broadcast quality is poor\",\n  \"description\": \"Recipients report static and dropped audio on outbound voice broadcasts.\",\n  \"priority\": \"high\",\n  \"category\": \"technical\",\n  \"status\": \"in_progress\",\n  \"assignee\": \"Voice Eng\",\n  \"customer_id\": \"{{customer_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets/",
              "host": ["{{base_url}}"],
              "path": ["tickets", ""]
            }
          }
        },
