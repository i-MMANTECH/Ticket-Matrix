# Emmanuel Aro's project submission for evaluation.
# Copy to backend/.env and fill in your real Supabase values.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# CORS — comma-separated origins of your Next.js frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Postgres connection
# Find these in Supabase Dashboard -> Project Settings -> Database -> Connection string
# Prefer the "Connection pooling" (Transaction mode, port 6543) URL for app traffic.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Optional Supabase keys (only needed if you call the Supabase HTTP/API directly)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=